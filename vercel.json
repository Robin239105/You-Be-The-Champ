{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "server/server.js",
      "use": "@vercel/node",
      "config": { "includeFiles": ["server/prisma/**"] }
    }
  ],

  "rewrites": [
    { "source": "/api/(.*)", "destination": "server/server.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
